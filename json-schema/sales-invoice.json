{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/microsoft-dynamics/refs/heads/main/json-schema/sales-invoice.json",
  "title": "Sales Invoice",
  "description": "A sales invoice in Microsoft Dynamics 365, representing a bill issued to a customer for goods or services.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "The unique identifier of the sales invoice.",
      "readOnly": true
    },
    "number": {
      "type": "string",
      "description": "The sales invoice number."
    },
    "invoiceDate": {
      "type": "string",
      "format": "date",
      "description": "The invoice date."
    },
    "postingDate": {
      "type": "string",
      "format": "date",
      "description": "The posting date."
    },
    "dueDate": {
      "type": "string",
      "format": "date",
      "description": "The payment due date."
    },
    "customerId": {
      "type": "string",
      "format": "uuid",
      "description": "The unique identifier of the customer."
    },
    "customerNumber": {
      "type": "string",
      "description": "The customer number."
    },
    "customerName": {
      "type": "string",
      "description": "The name of the customer.",
      "readOnly": true
    },
    "currencyCode": {
      "type": "string",
      "description": "The currency code for the invoice."
    },
    "status": {
      "type": "string",
      "description": "The status of the sales invoice.",
      "readOnly": true
    },
    "totalAmountExcludingTax": {
      "type": "number",
      "description": "The total amount excluding tax.",
      "readOnly": true
    },
    "totalAmountIncludingTax": {
      "type": "number",
      "description": "The total amount including tax.",
      "readOnly": true
    },
    "lastModifiedDateTime": {
      "type": "string",
      "format": "date-time",
      "description": "The date and time the record was last modified.",
      "readOnly": true
    }
  },
  "required": ["customerNumber"]
}
